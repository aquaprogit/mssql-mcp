# Copy to .env and adjust, or pass these variables in your MCP client config.

# --- Option A: full connection string (recommended for LocalDB) ---
DB_CONNECTION_STRING=Server=(localdb)\MSSQLLocalDB;Database=YourDatabase;Trusted_Connection=True;TrustServerCertificate=True;

# --- Option B: discrete settings (do not set DB_PORT for LocalDB) ---
# DB_SERVER=(localdb)\MSSQLLocalDB
# DB_DATABASE=YourDatabase
# DB_TRUST_CERT=true

# --- SQL authentication (omit DB_USER for Windows auth) ---
# DB_SERVER=localhost
# DB_DATABASE=YourDatabase
# DB_USER=sa
# DB_PASSWORD=your_password
# DB_PORT=1433
# DB_ENCRYPT=false
# DB_TRUST_CERT=true

# --- Driver overrides (optional) ---
# DB_DRIVER=msnodesqlv8
# DB_DRIVER=tedious
# DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# --- MCP server (optional) ---
# MCP_SERVER_NAME=mssql-mydb
# MCP_SERVER_VERSION=1.0.0
# MCP_LOG_QUERIES=true
